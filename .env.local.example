# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase
# Encontre estes valores em: https://supabase.com/dashboard -> Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sua_chave_publicavel_aqui

# Chave de servico (nunca exponha no cliente) - usada em lib/supabase/admin.ts
# para gestao de usuarios (criar/editar/excluir)
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui
